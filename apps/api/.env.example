PORT=4000
CORS_ORIGIN=http://localhost:5173

# Gemini for AI features
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Firebase Admin SDK — Project: helio-c65f5
FIREBASE_PROJECT_ID=helio-c65f5
FIREBASE_STORAGE_BUCKET=helio-c65f5.appspot.com

# Option 1 (recommended): paste the entire service-account JSON on one line
# Run this in your terminal to generate the value:
#   node -e "console.log(JSON.stringify(require('./serviceAccountKey.json')))"
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option 2: point to a local service-account file instead of pasting JSON
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\serviceAccountKey.json

# Seed default data into Firestore when collections are empty (set false to disable)
FIREBASE_BOOTSTRAP=true
