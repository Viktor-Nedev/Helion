PORT=4000
CORS_ORIGIN=http://localhost:5173

# Gemini for AI features
GEMINI_API_KEY=

# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# Option 1: paste the entire service account JSON on one line
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option 2: point GOOGLE_APPLICATION_CREDENTIALS to a local service-account file instead
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# Seed default data into Firestore if collections are empty
FIREBASE_BOOTSTRAP=true
